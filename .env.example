# ==================================================
# Lilo Netlify - Variáveis de Ambiente
# ==================================================
# IMPORTANTE: Estas variáveis devem ser configuradas no
# Netlify Dashboard → Site Settings → Environment Variables.
# NUNCA commitar este arquivo com valores reais.
# ==================================================

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- JWT ---
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cole-aqui-um-segredo-aleatorio-de-pelo-menos-32-caracteres

# --- Mercado Pago ---
# Public Key — pode ir para o frontend (mas o backend já entrega via /public-config)
MP_PUBLIC_KEY=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxx

# Access Token — NUNCA exponha! Apenas o backend usa.
MP_ACCESS_TOKEN=APP_USR-yyyyyyyyyyyyyyyyyyyyyyyy

# Webhook Secret — copie do painel do MP (Suas integrações → Webhooks → Configurar)
MP_WEBHOOK_SECRET=zzzzzzzzzzzzzzzzzzzzzzzz

# --- Planos (opcional, defaults: 29.90 e 299.00) ---
PLAN_MONTHLY_PRICE=29.90
PLAN_YEARLY_PRICE=299.00
